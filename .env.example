# Alarm Mail Service Configuration

# IMAP Configuration (Required)
ALARM_MAIL_IMAP_HOST=imap.mailserver.de
ALARM_MAIL_IMAP_PORT=993
ALARM_MAIL_IMAP_USE_SSL=true
ALARM_MAIL_IMAP_USERNAME=alarm@example.com
ALARM_MAIL_IMAP_PASSWORD=change-me
ALARM_MAIL_IMAP_MAILBOX=INBOX
ALARM_MAIL_IMAP_SEARCH=UNSEEN
ALARM_MAIL_POLL_INTERVAL=60

# ──────────────────────────────────────────────────────────────────────────────
# Push Targets
#
# Option A – Legacy single-target variables (backward-compatible)
#   Use these when you have exactly one alarm-monitor and/or one alarm-messenger.
#
# Option B – Numbered multi-target variables (TARGET_<N>_*)
#   Use these when you have multiple monitors/messengers at different sites.
#   Targets are numbered starting from 1.  Numbering must be consecutive
#   (discovery stops at the first missing TARGET_<N>_URL).
#
# Both options may be used simultaneously – the legacy targets are served in
# addition to all numbered targets.
# ──────────────────────────────────────────────────────────────────────────────

# Option A – Legacy Alarm Monitor Target (Optional)
# ALARM_MAIL_ALARM_MONITOR_URL=http://alarm-monitor:8000
# ALARM_MAIL_ALARM_MONITOR_API_KEY=your-monitor-api-key
# ALARM_MAIL_ALARM_MONITOR_VERIFY_SSL=true

# Option A – Legacy Alarm Messenger Target (Optional)
# ALARM_MAIL_ALARM_MESSENGER_URL=http://alarm-messenger:3000
# ALARM_MAIL_ALARM_MESSENGER_API_KEY=your-messenger-api-key
# ALARM_MAIL_ALARM_MESSENGER_VERIFY_SSL=true

# Option B – Example: two alarm-monitor instances for different dispatch groups
#
# Monitor for WIL28 / WIL29 (site 1)
# ALARM_MAIL_TARGET_1_TYPE=alarm-monitor
# ALARM_MAIL_TARGET_1_URL=http://monitor-site1:8000
# ALARM_MAIL_TARGET_1_API_KEY=generate-with-openssl-rand-hex-32
# ALARM_MAIL_TARGET_1_GROUPS=WIL28,WIL29
# ALARM_MAIL_TARGET_1_VERIFY_SSL=true
#
# Monitor for WIL30 / WIL31 (site 2)
# ALARM_MAIL_TARGET_2_TYPE=alarm-monitor
# ALARM_MAIL_TARGET_2_URL=http://monitor-site2:8000
# ALARM_MAIL_TARGET_2_API_KEY=generate-with-openssl-rand-hex-32
# ALARM_MAIL_TARGET_2_GROUPS=WIL30,WIL31
# ALARM_MAIL_TARGET_2_VERIFY_SSL=true
#
# Messenger with no group filter (receives all alarms)
# ALARM_MAIL_TARGET_3_TYPE=alarm-messenger
# ALARM_MAIL_TARGET_3_URL=http://messenger:3000
# ALARM_MAIL_TARGET_3_API_KEY=generate-with-openssl-rand-hex-32
# # no GROUPS set → forwards all alarms

# Advanced / Optional Settings
# ALARM_MAIL_HTTP_TIMEOUT=10
# ALARM_MAIL_LOG_LEVEL=INFO
# ALARM_MAIL_DEDUP_TTL=300
