# =========================================================================
# alarm-mail Konfiguration - Vollständige Vorlage
# =========================================================================
#
# Diese Datei enthält ALLE möglichen Konfigurationsoptionen für alarm-mail.
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an.
#
# WICHTIG: 
# - Committen Sie niemals die .env Datei in Git!
# - Die .env Datei ist bereits in .gitignore eingetragen
# - Verwenden Sie starke, zufällige Passwörter und API-Keys
#
# =========================================================================

# =========================================================================
# IMAP-Konfiguration (PFLICHT)
# Diese Einstellungen sind zwingend erforderlich
# =========================================================================

# Hostname oder IP-Adresse des IMAP-Servers
# Beispiele: imap.gmail.com, imap.mailbox.org, mail.feuerwehr.de
ALARM_MAIL_IMAP_HOST=imap.mailserver.de

# Benutzername für die IMAP-Anmeldung
# In den meisten Fällen die vollständige E-Mail-Adresse
ALARM_MAIL_IMAP_USERNAME=alarm@feuerwehr.de

# Passwort für die IMAP-Anmeldung
# Für Gmail/Outlook mit 2FA: App-Passwort verwenden!
# ⚠️ NIEMALS in Git committen!
# ⚠️ ERSETZEN SIE DIESEN PLATZHALTER MIT IHREM ECHTEN PASSWORT!
ALARM_MAIL_IMAP_PASSWORD=***HIER-IHR-ECHTES-PASSWORT-EINTRAGEN***

# =========================================================================
# IMAP-Erweiterte Einstellungen (Optional)
# Diese Einstellungen haben sinnvolle Standardwerte
# =========================================================================

# Port des IMAP-Servers
# Standard: 993 (SSL/TLS), 143 (unverschlüsselt - NICHT empfohlen)
ALARM_MAIL_IMAP_PORT=993

# SSL/TLS-Verschlüsselung verwenden
# Werte: true (empfohlen) oder false (nur für Tests!)
ALARM_MAIL_IMAP_USE_SSL=true

# Zu überwachender E-Mail-Ordner
# Standard: INBOX
# Andere Beispiele: "Alarme", "Einsätze", "Alarmierung"
# Hinweis: Groß-/Kleinschreibung beachten!
ALARM_MAIL_IMAP_MAILBOX=INBOX

# IMAP-Suchkriterium für E-Mails
# Standard: UNSEEN (nur ungelesene E-Mails)
# Andere Optionen:
#   - ALL (alle E-Mails)
#   - SEEN (nur gelesene E-Mails)
#   - SINCE "01-Dec-2024" (seit Datum)
#   - FROM "leitstelle@..." (von Absender)
# Mehrere Kriterien mit Leerzeichen kombinieren
ALARM_MAIL_IMAP_SEARCH=UNSEEN

# Polling-Intervall in Sekunden
# Wie oft soll nach neuen E-Mails gesucht werden?
# Standard: 60 Sekunden (1 Minute)
# Minimum: 10 Sekunden (nicht zu niedrig wählen!)
# Empfohlen: 30-120 Sekunden
ALARM_MAIL_POLL_INTERVAL=60

# =========================================================================
# alarm-monitor Integration (Optional)
# Aktiviert die Weiterleitung an das Dashboard
# =========================================================================

# Basis-URL des alarm-monitor Service
# Interne Docker-URL: http://alarm-monitor:8000
# Externe URL: https://monitor.ihre-feuerwehr.de
# Kommentieren Sie aus, wenn nicht verwendet
ALARM_MAIL_ALARM_MONITOR_URL=http://alarm-monitor:8000

# API-Key für alarm-monitor
# MUSS mit ALARM_DASHBOARD_API_KEY im alarm-monitor übereinstimmen!
# Mindestens 32 Zeichen, zufällig generiert
# Generierung: openssl rand -hex 32
# Kommentieren Sie aus, wenn nicht verwendet
ALARM_MAIL_ALARM_MONITOR_API_KEY=ihr-monitor-api-key-mindestens-32-zeichen

# =========================================================================
# alarm-messenger Integration (Optional)
# Aktiviert die mobile Alarmierung mit Push-Benachrichtigungen
# =========================================================================

# Basis-URL des alarm-messenger Service
# Interne Docker-URL: http://alarm-messenger:3000
# Externe URL: https://messenger.ihre-feuerwehr.de
# Kommentieren Sie aus, wenn nicht verwendet
ALARM_MAIL_ALARM_MESSENGER_URL=http://alarm-messenger:3000

# API-Key für alarm-messenger
# MUSS mit API_SECRET_KEY im alarm-messenger übereinstimmen!
# Mindestens 32 Zeichen, zufällig generiert
# Generierung: openssl rand -hex 32
# Kommentieren Sie aus, wenn nicht verwendet
ALARM_MAIL_ALARM_MESSENGER_API_KEY=ihr-messenger-api-key-mindestens-32-zeichen

# =========================================================================
# Hinweise und Best Practices
# =========================================================================
#
# 1. Minimale Konfiguration (nur E-Mail-Parsing):
#    Nur die IMAP-Pflichtfelder ausfüllen (HOST, USERNAME, PASSWORD)
#    Keine Target-URLs setzen
#
# 2. Mit alarm-monitor (Dashboard-Anzeige):
#    IMAP-Felder + ALARM_MONITOR_URL + ALARM_MONITOR_API_KEY
#
# 3. Mit alarm-messenger (Mobile Alarmierung):
#    IMAP-Felder + ALARM_MESSENGER_URL + ALARM_MESSENGER_API_KEY
#
# 4. All-in-One (beides):
#    Alle Felder ausfüllen für maximale Funktionalität
#
# 5. Sicherheit:
#    - Niemals diese Datei in Git committen!
#    - Verwenden Sie Docker Secrets in Produktion
#    - Rotieren Sie API-Keys regelmäßig (alle 90 Tage empfohlen)
#    - Verwenden Sie HTTPS für externe Verbindungen
#    - Aktivieren Sie immer IMAP_USE_SSL=true
#
# 6. Testen:
#    Starten Sie mit IMAP_SEARCH=ALL zum Testen
#    Setzen Sie danach zurück auf UNSEEN für Produktion
#
# 7. Gmail-spezifisch:
#    - App-Passwort generieren: https://myaccount.google.com/apppasswords
#    - IMAP in Gmail-Einstellungen aktivieren
#    - Eventuell "Weniger sichere Apps" erlauben
#
# 8. Outlook/Office365-spezifisch:
#    - App-Passwort verwenden bei aktivierter 2FA
#    - IMAP-Host: outlook.office365.com
#    - Port: 993, SSL: true
#
# =========================================================================
# Beispiel-Konfigurationen
# =========================================================================
#
# Beispiel 1: Nur Parsing (ohne Weiterleitung)
# -------------------------
# ALARM_MAIL_IMAP_HOST=imap.mailserver.de
# ALARM_MAIL_IMAP_USERNAME=alarm@feuerwehr.de
# ALARM_MAIL_IMAP_PASSWORD=passwort
#
# Beispiel 2: Mit alarm-monitor
# -------------------------
# ALARM_MAIL_IMAP_HOST=imap.mailserver.de
# ALARM_MAIL_IMAP_USERNAME=alarm@feuerwehr.de
# ALARM_MAIL_IMAP_PASSWORD=passwort
# ALARM_MAIL_ALARM_MONITOR_URL=http://alarm-monitor:8000
# ALARM_MAIL_ALARM_MONITOR_API_KEY=abc123def456...
#
# Beispiel 3: Vollständig
# -------------------------
# ALARM_MAIL_IMAP_HOST=imap.mailserver.de
# ALARM_MAIL_IMAP_PORT=993
# ALARM_MAIL_IMAP_USE_SSL=true
# ALARM_MAIL_IMAP_USERNAME=alarm@feuerwehr.de
# ALARM_MAIL_IMAP_PASSWORD=passwort
# ALARM_MAIL_IMAP_MAILBOX=INBOX
# ALARM_MAIL_IMAP_SEARCH=UNSEEN
# ALARM_MAIL_POLL_INTERVAL=60
# ALARM_MAIL_ALARM_MONITOR_URL=http://alarm-monitor:8000
# ALARM_MAIL_ALARM_MONITOR_API_KEY=abc123...
# ALARM_MAIL_ALARM_MESSENGER_URL=http://alarm-messenger:3000
# ALARM_MAIL_ALARM_MESSENGER_API_KEY=def456...
#
# =========================================================================
